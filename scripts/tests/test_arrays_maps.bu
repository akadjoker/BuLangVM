// ============================================
// test_arrays_maps.bu — Arrays, maps, iteration
// ============================================

var passed = 0;
var failed = 0;

def assert(cond, msg)
{
    if (cond) {
        passed += 1;
    } else {
        failed += 1;
        print(f"FAIL: {msg}");
    }
}

// Array basics
var a = [1, 2, 3];
assert(len(a) == 3, "array len");
assert(a[0] == 1, "array index 0");
assert(a[2] == 3, "array index 2");

// Array mutation
a[1] = 99;
assert(a[1] == 99, "array set");

// Array push/pop
a.push(4);
assert(len(a) == 4, "array push len");
assert(a[3] == 4, "array push val");

var popped = a.pop();
assert(popped == 4, "array pop val");
assert(len(a) == 3, "array pop len");

// Empty array
var empty = [];
assert(len(empty) == 0, "empty array");
empty.push("x");
assert(len(empty) == 1, "push to empty");

// Foreach array
var sum = 0;
var nums = [10, 20, 30, 40];
foreach (n in nums) {
    sum += n;
}
assert(sum == 100, "foreach sum");

// Nested arrays
var matrix = [[1, 2], [3, 4], [5, 6]];
assert(matrix[1][0] == 3, "nested array access");
assert(len(matrix) == 3, "nested array len");

// Map basics
var m = {name: "BuLang", version: 2};
assert(m["name"] == "BuLang", "map string key access");
assert(m["version"] == 2, "map int val");

// Map bracket access and set
m["year"] = 2026;
assert(m["year"] == 2026, "map set bracket");

print(f"test_arrays_maps: {passed} passed, {failed} failed");
