// ============================================
// test_structs_enums.bu — Structs & Enums
// ============================================

var passed = 0;
var failed = 0;

def assert(cond, msg)
{
    if (cond) {
        passed += 1;
    } else {
        failed += 1;
        print(f"FAIL: {msg}");
    }
}

// ── Structs ──────────────────────────────────

struct Vec2 { x, y }

var v = Vec2(10, 20);
assert(v.x == 10, "struct field x");
assert(v.y == 20, "struct field y");

// Struct mutation
v.x = 99;
assert(v.x == 99, "struct set field");

struct Color3 { var r, g, b; }

var c = Color3(255, 128, 0);
assert(c.r == 255, "struct var r");
assert(c.g == 128, "struct var g");
assert(c.b == 0, "struct var b");

// ── Enums ────────────────────────────────────

// Explicit values
enum Color {
    Red = 1,
    Green = 2,
    Blue = 3
}
assert(Color.Red == 1, "enum explicit Red");
assert(Color.Green == 2, "enum explicit Green");
assert(Color.Blue == 3, "enum explicit Blue");

// Auto-increment from 0
enum Direction {
    Up,
    Down,
    Left,
    Right
}
assert(Direction.Up == 0, "enum auto Up");
assert(Direction.Down == 1, "enum auto Down");
assert(Direction.Left == 2, "enum auto Left");
assert(Direction.Right == 3, "enum auto Right");

// Mixed explicit values
enum HttpStatus {
    OK = 200,
    NotFound = 404,
    Error = 500
}
assert(HttpStatus.OK == 200, "enum http 200");
assert(HttpStatus.NotFound == 404, "enum http 404");
assert(HttpStatus.Error == 500, "enum http 500");

// Enum in expressions
var status = HttpStatus.OK;
if (status == HttpStatus.OK) {
    assert(true, "enum comparison");
} else {
    assert(false, "enum comparison");
}

// Enum in f-string
assert(f"status={HttpStatus.NotFound}" == "status=404", "enum in f-string");

// Enum arithmetic
assert(Color.Red + Color.Blue == 4, "enum arithmetic add");
assert(Color.Blue - Color.Red == 2, "enum arithmetic sub");
assert(Color.Green * 2 == 4, "enum arithmetic mult");

// Enum in array
var codes = [HttpStatus.OK, HttpStatus.NotFound, HttpStatus.Error];
assert(codes[0] == 200, "enum in array[0]");
assert(codes[1] == 404, "enum in array[1]");
assert(codes[2] == 500, "enum in array[2]");

// Enum in map value
var statusMap = {
    "success": HttpStatus.OK,
    "missing": HttpStatus.NotFound
};
assert(statusMap["success"] == 200, "enum in map value");
assert(statusMap["missing"] == 404, "enum in map value 2");

// Enum comparison operators
assert(Direction.Up < Direction.Down, "enum less than");
assert(Direction.Right > Direction.Left, "enum greater than");
assert(Direction.Down >= Direction.Down, "enum greater or eq");
assert(Direction.Up <= Direction.Up, "enum less or eq");

// Enum with explicit and auto-increment mix
enum Priority {
    Low = 10,
    Medium,     // 11
    High,       // 12
    Critical = 100,
    Urgent      // 101
}
assert(Priority.Low == 10, "enum mixed Low");
assert(Priority.Medium == 11, "enum mixed Medium auto");
assert(Priority.High == 12, "enum mixed High auto");
assert(Priority.Critical == 100, "enum mixed Critical");
assert(Priority.Urgent == 101, "enum mixed Urgent auto");

// Enum in ternary
var level = Priority.High;
var txt = level > Priority.Medium ? "important" : "normal";
assert(txt == "important", "enum in ternary");

// Enum as function argument
def checkStatus(s) {
    return s == HttpStatus.OK;
}
assert(checkStatus(HttpStatus.OK) == true, "enum as func arg");
assert(checkStatus(HttpStatus.Error) == false, "enum as func arg 2");

// Enum return from function
def getDefaultStatus() {
    return HttpStatus.OK;
}
assert(getDefaultStatus() == 200, "enum as func return");

// Enum in switch
var msg = "";
switch (status) {
    case 200:
        msg = "ok";
    case 404:
        msg = "not found";
    default:
        msg = "unknown";
}
assert(msg == "ok", "enum switch");

print(f"test_structs_enums: {passed} passed, {failed} failed");
