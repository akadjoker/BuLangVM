// ============================================
// test_evil_edge_cases.bu — Really nasty edge cases
// The kind of stuff that breaks VMs
// ============================================

var passed = 0;
var failed = 0;

def assert(cond, msg) {
    if (cond) {
        passed += 1;
    } else {
        failed += 1;
        print(f"FAIL: {msg}\n");
    }
}

// ==== 1. Empty everything ====
var empty_arr = [];
var empty_map = {};
var empty_str = "";
assert(empty_arr.length() == 0, "empty array length");
assert(empty_str.length() == 0, "empty string length");

// ==== 2. Single element operations ====
var single = [42];
assert(single.pop() == 42, "pop single element");
assert(single.length() == 0, "now empty after pop");

// ==== 3. Zero and negative numbers ====
assert(0 == -0, "zero equals negative zero");
assert(-0.0 == 0.0, "float zero equals negative");
assert(0 * -1 == 0, "0 * -1");
assert(-1 * 0 == 0, "-1 * 0");

// ==== 4. Boolean coercion edge cases ====
assert(!nil == true, "!nil");
assert(!0 == true, "!0");
assert(!1 == false, "!1");
assert(!!1 == true, "!!1");
assert(!!!1 == false, "!!!1");

// ==== 5. String edge cases ====
var special_str = "hello\nworld\ttab\\slash";
assert(special_str.length() == 21, "escape sequences length");

// ==== 6. Number precision ====
var precise = 0.1 + 0.2;
// Should be approximately 0.3 (floating point)
assert(precise > 0.29 && precise < 0.31, "float precision 0.1+0.2");

// ==== 7. Large numbers ====
var big = 2147483647;  // INT_MAX
var big_plus = big + 1;  // Overflow
assert(big_plus < big, "int overflow wraps");

// ==== 8. Division edge cases ====
assert(5 / 2 == 2.5, "int division produces float");
assert(4 / 2 == 2, "exact division");
assert(1 / 3 > 0.33 && 1 / 3 < 0.34, "1/3 precision");

// ==== 9. Modulo edge cases ====
assert(5 % 3 == 2, "positive modulo");
assert(-5 % 3 == -2, "negative modulo");
assert(5 % -3 == 2, "modulo negative divisor");
assert(0 % 5 == 0, "0 % n");

// ==== 10. Assignment in expressions ====
var x = 0;
var y = (x = 5);
assert(x == 5, "assignment side effect");
assert(y == 5, "assignment returns value");

// ==== 11. Chained assignment ====
var ca; var cb; var cc;
ca = cb = cc = 100;
assert(ca == 100 && cb == 100 && cc == 100, "chained assignment");

// ==== 12. Short-circuit evaluation ====
var side_effect = 0;
def has_effect() {
    side_effect = 1;
    return true;
}

var sc1 = false && has_effect();  // Should NOT call has_effect
assert(side_effect == 0, "short-circuit &&");

side_effect = 0;
var sc2 = true || has_effect();  // Should NOT call has_effect
assert(side_effect == 0, "short-circuit ||");

// ==== 13. Compound assignment edge cases ====
var comp = 10;
comp += 5;
assert(comp == 15, "+= basic");
comp -= 3;
assert(comp == 12, "-= basic");
comp *= 2;
assert(comp == 24, "*= basic");
comp /= 4;
assert(comp == 6, "/= basic");
comp %= 4;
assert(comp == 2, "%= basic");

// ==== 14. Array index expressions ====
var idx_arr = [10, 20, 30, 40, 50];
var idx = 2;
assert(idx_arr[idx] == 30, "variable index");
assert(idx_arr[idx + 1] == 40, "expression index");
assert(idx_arr[idx_arr[0] / 10] == 20, "nested index expression");

// ==== 15. Map with numeric string keys ====
var num_map = {"0": "zero", "1": "one", "2": "two"};
assert(num_map["0"] == "zero", "numeric string key");

// ==== 16. Method on literal ====
assert("hello".length() == 5, "method on string literal");
assert([1, 2, 3].length() == 3, "method on array literal");

// ==== 17. Chained string methods ====
assert("  hello  ".trim().upper() == "HELLO", "chained string methods");

// ==== 18. Nil handling ====
def with_nil_check(a, b) {
    if (b == nil) b = 10;
    return a + b;
}
assert(with_nil_check(5, nil) == 15, "nil default");
assert(with_nil_check(5, 3) == 8, "override nil");

// ==== 19. Linked list traversal ====
var node = {"value": 1, "next": nil};
node["next"] = {"value": 2, "next": nil};
node["next"]["next"] = {"value": 3, "next": nil};

var sum = 0;
var curr = node;
while (curr != nil) {
    sum += curr["value"];
    curr = curr["next"];
}
assert(sum == 6, "linked list traversal");

// ==== 20. Exception in complex expression ====
var exc_complex = 0;
try {
    exc_complex = 1 + 2 + (3 / 0) + 4 + 5;
} catch (e) {
    exc_complex = -1;
}
assert(exc_complex == -1, "exception in middle of expression");

// ==== 21. Inheritance and super ====
class Base {
    def foo() { return "base"; }
}

class Derived : Base {
    def foo() { return "derived"; }
    def bar() { return super.foo(); }
}

var d = Derived();
assert(d.foo() == "derived", "override method");
assert(d.bar() == "base", "super call");

// ==== 22. This/self in closure ====
class Container {
    var value;
    def init() {
        self.value = 42;
    }
    def get_getter() {
        var v = self.value;  // Capture value, not self
        def getter() {
            return v;
        }
        return getter;
    }
}

var cont = Container();
var inner_fn = cont.get_getter();
assert(inner_fn() == 42, "value captured in closure");

// ==== 23. Bitwise operations ====
assert((5 & 3) == 1, "bitwise and");
assert((5 | 3) == 7, "bitwise or");
assert((5 ^ 3) == 6, "bitwise xor");
assert(~0 == -1, "bitwise not");
assert((1 << 4) == 16, "left shift");
assert((16 >> 2) == 4, "right shift");

// ==== 24. Comparison edge cases ====
var cmp_a = 5;
var cmp_b = 10;
var cmp_c = 10;
assert((cmp_a < cmp_b) == true, "less than");
assert((cmp_b == cmp_c) == true, "equals");
assert((cmp_b <= cmp_c) == true, "less or equal same");
assert((cmp_a >= cmp_a) == true, "greater or equal same");

// ==== 25. String comparison ====
assert("abc" == "abc", "string equals");
assert("ABC" != "abc", "string case sensitive");

// ==== 26. Nil comparisons ====
assert(nil == nil, "nil equals nil");
assert((nil != 0) == true, "nil not equals 0");
assert((nil != "") == true, "nil not equals empty string");

// ==== 27. Array reference ====
var arr1 = [1, 2, 3];
var arr2 = [1, 2, 3];
var arr3 = arr1;
// Arrays are reference types
assert(arr1 == arr3, "same array reference");

// ==== 28. Map modification during use ====
var mod_map = {"a": 1, "b": 2};
mod_map["c"] = mod_map["a"] + mod_map["b"];
assert(mod_map["c"] == 3, "map self-reference modification");

// ==== 29. Function as map value ====
var fn_map = {};
def add_fn(a, b) { return a + b; }
def mul_fn(a, b) { return a * b; }
fn_map["add"] = add_fn;
fn_map["mul"] = mul_fn;
assert(fn_map["add"](3, 4) == 7, "function in map");
assert(fn_map["mul"](3, 4) == 12, "function in map 2");

// ==== 30. Deeply nested conditionals ====
def nested_cond(a, b, c, d) {
    if (a > 0) {
        if (b > 0) {
            if (c > 0) {
                if (d > 0) {
                    return "all positive";
                } else {
                    return "d not positive";
                }
            } else {
                return "c not positive";
            }
        } else {
            return "b not positive";
        }
    } else {
        return "a not positive";
    }
}
assert(nested_cond(1, 1, 1, 1) == "all positive", "nested conditionals");
assert(nested_cond(1, 1, 1, 0) == "d not positive", "nested conditionals 2");

print(f"\n=== test_evil_edge_cases: {passed}/{passed + failed} ===\n");
if (failed > 0) {
    print(f"FAILED: {failed} tests\n");
}
