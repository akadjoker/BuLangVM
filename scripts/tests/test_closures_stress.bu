// ============================================
// test_closures_stress.bu — closures, upvalues, higher-order functions
// ============================================

var passed = 0;
var failed = 0;

def assert(cond, msg)
{
    if (cond) {
        passed += 1;
    } else {
        failed += 1;
        print(f"FAIL: {msg}");
    }
}

// ==== 1. Closure captures variable by reference ====
def make_counter()
{
    var count = 0;
    def increment() {
        count += 1;
        return count;
    }
    return increment;
}

var counter = make_counter();
assert(counter() == 1, "counter 1");
assert(counter() == 2, "counter 2");
assert(counter() == 3, "counter 3");

// ==== 2. Multiple closures over same variable ====
def make_pair()
{
    var value = 0;
    def getter() { return value; }
    def setter(v) { value = v; }
    return [getter, setter];
}

var pair = make_pair();
var getter = pair[0];
var setter = pair[1];
assert(getter() == 0, "getter init");
setter(42);
assert(getter() == 42, "setter->getter 42");
setter(-1);
assert(getter() == -1, "setter->getter -1");

// ==== 3. Closure in loop - capture via function param ====
var funcs = [];
for (var i = 0; i < 5; i += 1) {
    def make_fn(val) {
        def fn() { return val; }
        return fn;
    }
    funcs.push(make_fn(i));
}
assert(funcs[0]() == 0, "closure loop 0");
assert(funcs[1]() == 1, "closure loop 1");
assert(funcs[4]() == 4, "closure loop 4");

// ==== 4. Nested closures - 2 levels deep ====
def outer()
{
    var a = "A";
    def middle() {
        var b = a + "B";
        def inner() { return b + "C"; }
        return inner;
    }
    return middle;
}

var mid = outer();
var inn = mid();
assert(inn() == "ABC", "nested closure 2 levels");

// ==== 5. Recursive closure ====
def make_fibonacci()
{
    def fib(n) {
        if (n <= 1) { return n; }
        return fib(n - 1) + fib(n - 2);
    }
    return fib;
}

var fib = make_fibonacci();
assert(fib(0) == 0, "fib 0");
assert(fib(1) == 1, "fib 1");
assert(fib(10) == 55, "fib 10");

// ==== 6. Higher-order functions ====
def apply(fn, value) { return fn(value); }
def double_it(x) { return x * 2; }
def negate(x) { return -x; }

assert(apply(double_it, 5) == 10, "apply double");
assert(apply(negate, 3) == -3, "apply negate");
assert(apply(double_it, apply(negate, 4)) == -8, "compose apply");

// ==== 7. Returning function from conditional ====
def pick_op(name)
{
    if (name == "add") {
        def add(a, b) { return a + b; }
        return add;
    } else {
        def sub(a, b) { return a - b; }
        return sub;
    }
}

var add_fn = pick_op("add");
var sub_fn = pick_op("sub");
assert(add_fn(10, 3) == 13, "pick add");
assert(sub_fn(10, 3) == 7, "pick sub");

// ==== 8. Closure as accumulator ====
def make_accumulator(initial)
{
    var total = initial;
    def add(n) {
        total += n;
        return total;
    }
    return add;
}

var acc = make_accumulator(0);
assert(acc(5) == 5, "acc 5");
assert(acc(3) == 8, "acc +3");
assert(acc(10) == 18, "acc +10");

// ==== Summary ====
print(f"=== test_closures_stress: {passed}/{passed + failed} ===");
if (failed > 0) {
    print(f"FAILED: {failed} tests");
    exit(1);
}
