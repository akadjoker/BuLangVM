// ============================================
// test_strings.bu — String operations, f-strings, methods
// ============================================

var passed = 0;
var failed = 0;

def assert(cond, msg)
{
    if (cond) {
        passed += 1;
    } else {
        failed += 1;
        print(f"FAIL: {msg}");
    }
}

// Basic strings
var s = "hello";
assert(len(s) == 5, "len() string");

// Concatenation
assert("foo" + "bar" == "foobar", "concat");
assert("" + "a" == "a", "concat empty");

// Escape sequences
var nl = "a\nb";
assert(len(nl) == 3, "newline escape length");
var tab = "a\tb";
assert(len(tab) == 3, "tab escape length");

// F-string basics
var name = "BuLang";
assert(f"Hello {name}" == "Hello BuLang", "f-string var");
assert(f"{1 + 2}" == "3", "f-string expr");
assert(f"" == "", "f-string empty");
assert(f"no interp" == "no interp", "f-string no interp");

// F-string escaped braces
assert(f"{{x}}" == "{x}", "f-string escaped braces");

// F-string nested expressions
var arr = [10, 20, 30];
assert(f"len={len(arr)}" == "len=3", "f-string len call");

// F-string with multiple placeholders
var x = 10;
var y = 20;
assert(f"x={x}, y={y}" == "x=10, y=20", "f-string multi vars");
assert(f"{x}+{y}={x+y}" == "10+20=30", "f-string multi exprs");

// F-string with math expressions
assert(f"{2*3*4}" == "24", "f-string mult");
assert(f"{100/4}" == "25", "f-string div");
assert(f"{17%5}" == "2", "f-string mod");
assert(f"{-42}" == "-42", "f-string negative");

// F-string with ternary
var flag = true;
var ternaryResult = flag ? "yes" : "no";
assert(f"{ternaryResult}" == "yes", "f-string ternary true");
flag = false;
ternaryResult = flag ? "yes" : "no";
assert(f"{ternaryResult}" == "no", "f-string ternary false");

// F-string with array access
var nums = [100, 200, 300];
assert(f"first={nums[0]}" == "first=100", "f-string array[0]");
assert(f"last={nums[-1]}" == "last=300", "f-string array[-1]");

// F-string with map access
var obj = {"name": "Test", "value": 42};
var objName = obj["name"];
assert(f"name={objName}" == "name=Test", "f-string map access");

// F-string with function call
def double(n) { return n * 2; }
assert(f"doubled={double(5)}" == "doubled=10", "f-string func call");

// F-string with nested braces
assert(f"{{literal}}" == "{literal}", "f-string double brace");
assert(f"a{{b}}c" == "a{b}c", "f-string mixed braces");

// F-string with booleans
assert(f"{true}" == "true", "f-string true");
assert(f"{false}" == "false", "f-string false");

// F-string with nil
assert(f"{nil}" == "nil", "f-string nil");

// F-string concatenation
var part1 = f"Hello ";
var part2 = f"{name}!";
assert(part1 + part2 == "Hello BuLang!", "f-string concat");

// String comparison
assert("abc" == "abc", "string eq");
assert("abc" != "def", "string neq");

// String repeat (via loop)
var rep = "";
for (var i = 0; i < 3; i += 1) {
    rep += "ab";
}
assert(rep == "ababab", "string repeat via concat");

// Multiline (implicit via escape)
var multi = "line1\nline2";
assert(len(multi) == 11, "multiline string length");

print(f"test_strings: {passed} passed, {failed} failed");
