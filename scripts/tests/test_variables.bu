// ============================================
// test_variables.bu — Variables & basic types
// ============================================

var passed = 0;
var failed = 0;

def assert(cond, msg)
{
    if (cond) {
        passed += 1;
    } else {
        failed += 1;
        print(f"FAIL: {msg}");
    }
}

// var declaration
var a = 10;
assert(a == 10, "var int");

var b = 3.14;
assert(b > 3.13, "var float low");
assert(b < 3.15, "var float high");

var s = "hello";
assert(s == "hello", "var string");

var n = nil;
assert(n == nil, "var nil");

var t = true;
var f = false;
assert(t == true, "var true");
assert(f == false, "var false");

// multiple var
var x = 1, y = 2, z = 3;
assert(x == 1, "multi var x");
assert(y == 2, "multi var y");
assert(z == 3, "multi var z");

// reassign
x = 100;
assert(x == 100, "reassign");

// compound assignment
var c = 10;
c += 5;
assert(c == 15, "+= operator");
c -= 3;
assert(c == 12, "-= operator");
c *= 2;
assert(c == 24, "*= operator");
c /= 4;
assert(c == 6, "/= operator");
c %= 4;
assert(c == 2, "%= operator");

print(f"test_variables: {passed} passed, {failed} failed");
