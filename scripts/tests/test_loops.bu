// ============================================
// test_loops.bu — while, do-while, for, foreach, nested loops, break/continue
// ============================================

var passed = 0;
var failed = 0;

def assert(cond, msg)
{
    if (cond) {
        passed += 1;
    } else {
        failed += 1;
        print(f"FAIL: {msg}");
    }
}

// ── while basic ──────────────────────────────

var sum = 0;
var i = 1;
while (i <= 100) {
    sum += i;
    i += 1;
}
assert(sum == 5050, "while sum 1..100");

// while false body never runs
var ran = false;
while (false) {
    ran = true;
}
assert(!ran, "while false never runs");

// while single iteration
var count = 0;
while (count < 1) {
    count += 1;
}
assert(count == 1, "while single iteration");

// ── while + break ────────────────────────────

sum = 0;
i = 0;
while (true) {
    if (i >= 10) break;
    sum += i;
    i += 1;
}
assert(sum == 45, "while break at 10");

// break exits only innermost loop
var outer = 0;
var inner_count = 0;
i = 0;
while (i < 3) {
    var j = 0;
    while (true) {
        if (j >= 2) break;
        inner_count += 1;
        j += 1;
    }
    outer += 1;
    i += 1;
}
assert(outer == 3, "nested break outer runs 3x");
assert(inner_count == 6, "nested break inner runs 6x");

// ── while + continue ─────────────────────────

// skip even numbers
sum = 0;
i = 0;
while (i < 10) {
    i += 1;
    if (i % 2 == 0) continue;
    sum += i;
}
assert(sum == 25, "while continue skip evens");

// continue in nested loop
var result = 0;
i = 0;
while (i < 3) {
    var j = 0;
    while (j < 3) {
        j += 1;
        if (j == 2) continue;
        result += 1;
    }
    i += 1;
}
assert(result == 6, "nested continue");

// ── do-while ─────────────────────────────────

count = 0;
do {
    count += 1;
} while (count < 5);
assert(count == 5, "do-while basic");

// do-while runs at least once even if false
count = 0;
do {
    count += 1;
} while (false);
assert(count == 1, "do-while runs once when false");

// do-while with break
count = 0;
do {
    count += 1;
    if (count == 3) break;
} while (count < 10);
assert(count == 3, "do-while break");

// NOTE: do-while + continue has a known bug (continue jumps to body start,
// not to condition), so we skip that test for now.

// ── for loop ─────────────────────────────────

sum = 0;
for (var k = 0; k < 10; k += 1) {
    sum += k;
}
assert(sum == 45, "for loop 0..9");

// for with break
sum = 0;
for (var k = 0; k < 100; k += 1) {
    if (k >= 5) break;
    sum += k;
}
assert(sum == 10, "for break at 5");

// for with continue
sum = 0;
for (var k = 0; k < 10; k += 1) {
    if (k % 3 == 0) continue;
    sum += k;
}
assert(sum == 27, "for continue skip multiples of 3");

// for nested
count = 0;
for (var a = 0; a < 4; a += 1) {
    for (var b = 0; b < 3; b += 1) {
        count += 1;
    }
}
assert(count == 12, "for nested 4x3");

// ── foreach ──────────────────────────────────

var arr = [10, 20, 30, 40, 50];
sum = 0;
foreach (v in arr) {
    sum += v;
}
assert(sum == 150, "foreach array sum");

// foreach with break
sum = 0;
foreach (v in [1, 2, 3, 4, 5]) {
    if (v > 3) break;
    sum += v;
}
assert(sum == 6, "foreach break");

// foreach with continue
sum = 0;
foreach (v in [1, 2, 3, 4, 5, 6]) {
    if (v % 2 == 0) continue;
    sum += v;
}
assert(sum == 9, "foreach continue odds");

// NOTE: foreach over string is not supported (strings are not iterable)

// ── nested mixed loops ───────────────────────

// while inside for
count = 0;
for (var x = 0; x < 3; x += 1) {
    var y = 0;
    while (y < 2) {
        count += 1;
        y += 1;
    }
}
assert(count == 6, "while inside for");

// for inside while
count = 0;
i = 0;
while (i < 2) {
    for (var x = 0; x < 3; x += 1) {
        count += 1;
    }
    i += 1;
}
assert(count == 6, "for inside while");

// three levels deep
count = 0;
for (var a = 0; a < 2; a += 1) {
    for (var b = 0; b < 2; b += 1) {
        var c = 0;
        while (c < 2) {
            count += 1;
            c += 1;
        }
    }
}
assert(count == 8, "three nested loops 2x2x2");

// ── loop with function calls ─────────────────

def double(n) { return n * 2; }

sum = 0;
for (var k = 1; k <= 5; k += 1) {
    sum += double(k);
}
assert(sum == 30, "loop calling function");

// loop building array
var built = [];
for (var k = 0; k < 5; k += 1) {
    built.push(k * k);
}
assert(len(built) == 5, "loop build array len");
assert(built[0] == 0, "loop build arr[0]");
assert(built[4] == 16, "loop build arr[4]");

// ── loop with struct/class ───────────────────

struct Pair { a, b }

var pairs = [];
for (var k = 0; k < 3; k += 1) {
    pairs.push(Pair(k, k * 10));
}
assert(pairs[0].a == 0, "loop struct a[0]");
assert(pairs[2].b == 20, "loop struct b[2]");

print(f"test_loops: {passed} passed, {failed} failed");
