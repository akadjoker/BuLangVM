require "Box2D";

import Box2D;
using Box2D;

// ================================================================
// Box2D callback bridge test
// Validates:
//   - DebugDraw bridge
//   - ContactListener bridge
//   - QueryCallback bridge
//   - RayCastCallback bridge
// ================================================================

var dbgPolygon = 0;
var dbgSolidPolygon = 0;
var dbgCircle = 0;
var dbgSolidCircle = 0;
var dbgSegment = 0;
var dbgTransform = 0;
var dbgPoint = 0;

var cBegin = 0;
var cEnd = 0;
var cPre = 0;
var cPost = 0;

var qHits = 0;
var rHits = 0;

class TestDebugDraw:B2DebugDraw
{
    def init()
    {
        self.setFlags(B2_DRAW_SHAPE_BIT);
        self.appendFlags(B2_DRAW_CENTER_OF_MASS_BIT);
    }

    def DrawPolygon(vertices, r, g, b) { dbgPolygon = dbgPolygon + 1; }
    def DrawSolidPolygon(vertices, r, g, b) { dbgSolidPolygon = dbgSolidPolygon + 1; }
    def DrawCircle(cx, cy, radius, r, g, b) { dbgCircle = dbgCircle + 1; }
    def DrawSolidCircle(cx, cy, radius, axisX, axisY, r, g, b) { dbgSolidCircle = dbgSolidCircle + 1; }
    def DrawSegment(x1, y1, x2, y2, r, g, b) { dbgSegment = dbgSegment + 1; }
    def DrawTransform(px, py, qs, qc) { dbgTransform = dbgTransform + 1; }
    def DrawPoint(px, py, size, r, g, b) { dbgPoint = dbgPoint + 1; }
}

class TestContact:B2ContactListener
{
    def BeginContact(a, b) { cBegin = cBegin + 1; }
    def EndContact(a, b) { cEnd = cEnd + 1; }
    def PreSolve(a, b) { cPre = cPre + 1; }
    def PostSolve(a, b) { cPost = cPost + 1; }
}

class TestQuery:B2QueryCallback
{
    def ReportFixture(body)
    {
        qHits = qHits + 1;
        return true;
    }
}

class TestRay:B2RayCastCallback
{
    def ReportFixture(body, px, py, nx, ny, fraction)
    {
        rHits = rHits + 1;
        return 1.0;
    }
}

var world = B2World(0.0, -10.0);

var dd = TestDebugDraw();
var cl = TestContact();
var qc = TestQuery();
var rc = TestRay();

world.setDebugDraw(dd);
world.setContactListener(cl);

// Ground
var bdGround = B2BodyDef();
bdGround.setType(B2_STATIC_BODY);
bdGround.setPosition(0.0, -1.0);
var shGround = B2PolygonShape();
shGround.setAsBox(10.0, 1.0);
var fdGround = B2FixtureDef();
fdGround.setShape(shGround);
var ground = world.createBody(bdGround);
ground.createFixture(fdGround);

// Dynamic box
var bdBox = B2BodyDef();
bdBox.setType(B2_DYNAMIC_BODY);
bdBox.setPosition(0.0, 4.0);
var shBox = B2PolygonShape();
shBox.setAsBox(0.5, 0.5);
var fdBox = B2FixtureDef();
fdBox.setShape(shBox);
fdBox.setDensity(1.0);
fdBox.setFriction(0.3);
var box = world.createBody(bdBox);
box.createFixture(fdBox);

// Run sim long enough for collision
for (var i = 0; i < 180; i++)
{
    world.step(1.0 / 60.0, 8, 3);
    if ((i % 30) == 0) world.debugDraw();
}
world.debugDraw();

var queryCount = world.queryAABB(qc, -2.0, -2.0, 2.0, 2.0);
var rayCount = world.rayCast(rc, -5.0, 5.0, 5.0, -5.0);

var dbgTotal = dbgPolygon + dbgSolidPolygon + dbgCircle + dbgSolidCircle + dbgSegment + dbgTransform + dbgPoint;

var okDebug = dbgTotal > 0;
var okContact = (cBegin > 0) && (cPre > 0 || cPost > 0);
var okQuery = (queryCount > 0) && (qHits > 0);
var okRay = (rayCount > 0) && (rHits > 0);

print("DBG: poly=" + dbgPolygon + " solidPoly=" + dbgSolidPolygon + " circle=" + dbgCircle + " solidCircle=" + dbgSolidCircle + " seg=" + dbgSegment + " xf=" + dbgTransform + " pt=" + dbgPoint);
print("CONTACT: begin=" + cBegin + " end=" + cEnd + " pre=" + cPre + " post=" + cPost);
print("QUERY: world=" + queryCount + " callback=" + qHits);
print("RAY: world=" + rayCount + " callback=" + rHits);

if (okDebug && okContact && okQuery && okRay)
{
    print("BOX2D_CALLBACKS_TEST_PASS");
}
else
{
    print("BOX2D_CALLBACKS_TEST_FAIL");
}

world.destroy();
