def fail(msg)
{
    print("NATIVE_PERSISTENT_GC_FAIL", msg);
}

def expectEq(actual, expected, msg)
{
    if (actual != expected)
    {
        fail(format("{} expected={} actual={}", msg, expected, actual));
        return false;
    }
    return true;
}

def expect(cond, msg)
{
    if (!cond)
    {
        fail(msg);
        return false;
    }
    return true;
}

_gcProbeReset();

var ephemeral = GcEphemeralProbe(7);
if (!expect(classname(ephemeral) == "GcEphemeralProbe", "ephemeral classname")) return;
if (!expectEq(ephemeral.id(), 7, "ephemeral id before gc")) return;
if (!expect(ephemeral.isPersistent() == false, "ephemeral persistence flag")) return;
if (!expectEq(_gcProbeEphemeralCtorCount(), 1, "ephemeral ctor count after create")) return;
if (!expectEq(_gcProbeEphemeralDtorCount(), 0, "ephemeral dtor count after create")) return;

_gc();
if (!expectEq(ephemeral.id(), 7, "ephemeral survives gc while referenced")) return;
if (!expectEq(_gcProbeEphemeralDtorCount(), 0, "ephemeral not destroyed while referenced")) return;

ephemeral = nil;
_gc();
if (!expectEq(_gcProbeEphemeralDtorCount(), 1, "ephemeral destroyed after losing references")) return;

var persistent = GcPersistentProbe(11);
if (!expect(classname(persistent) == "GcPersistentProbe", "persistent classname")) return;
if (!expectEq(persistent.id(), 11, "persistent id before gc")) return;
if (!expect(persistent.isPersistent() == true, "persistent flag")) return;
if (!expectEq(_gcProbePersistentCtorCount(), 1, "persistent ctor count after create")) return;
if (!expectEq(_gcProbePersistentDtorCount(), 0, "persistent dtor count after create")) return;

_gc();
if (!expectEq(persistent.id(), 11, "persistent survives gc while referenced")) return;
if (!expectEq(_gcProbePersistentDtorCount(), 0, "persistent not destroyed while referenced")) return;

persistent = nil;
_gc();
_gc();
if (!expectEq(_gcProbePersistentDtorCount(), 0, "persistent ignored by gc after losing references")) return;

print("NATIVE_PERSISTENT_GC_PASS");
