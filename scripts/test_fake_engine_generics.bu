include "fake_engine_core.bu";

def fail(msg)
{
    print("FAKE_ENGINE_GENERIC_FAIL", msg);
}

def expect(cond, msg)
{
    if (!cond)
    {
        fail(msg);
        return false;
    }
    return true;
}

def expectEq(actual, expected, msg)
{
    if (actual != expected)
    {
        fail(format("{} expected={} actual={}", msg, expected, actual));
        return false;
    }
    return true;
}

_gcProbeReset();

var world = FakeEngineWorld();
var go = world.createGameObject("Player");

var transform = go.addComponent<Transform2D>();
transform.x = 3.0;
transform.y = 1.5;

var sprite = go.addComponent<SpriteRenderer>();
sprite.width = 2.0;
sprite.height = 0.8;

var health = go.addComponent<Health>();
health.value = 75.0;
health.maximum = 100.0;

var spin = go.addComponent<SpinScript>();
spin.speed = 180.0;

var bob = go.addComponent<BobScript>();
bob.speed = 4.0;
bob.amplitude = 2.0;

if (!expect(go.hasComponent<Transform2D>(), "has Transform2D")) return;
if (!expect(go.hasComponent<SpriteRenderer>(), "has SpriteRenderer")) return;
if (!expect(go.hasComponent<Health>(), "has Health")) return;
if (!expectEq(typeid(Transform2D), typeid(transform), "Transform2D typeid matches instance")) return;
if (!expectEq(typeid(SpriteRenderer), typeid(sprite), "SpriteRenderer typeid matches instance")) return;
if (!expectEq(typeid(Health), typeid(health), "Health typeid matches instance")) return;
if (!expectEq(typeid(SpinScript), typeid(spin), "SpinScript typeid matches instance")) return;

var sameTransform = go.addComponent<Transform2D>();
if (!expectEq(sameTransform.x, 3.0, "duplicate add returns existing transform")) return;
if (!expectEq(go.componentCount(), 5, "component count after adds")) return;

var yBefore = transform.y;
world.update(0.25);
world.update(0.25);

if (!expect(transform.rotationDeg != 0.0, "SpinScript updates rotation")) return;
if (!expect(transform.y != yBefore, "BobScript updates y")) return;
if (!expectEq(go.getComponentByIndex(0).gameObject.id, go.id, "component gameObject backlink")) return;

if (!expect(go.removeComponent<SpriteRenderer>(), "remove SpriteRenderer succeeds")) return;
if (!expect(!go.hasComponent<SpriteRenderer>(), "SpriteRenderer removed")) return;
if (!expectEq(go.componentCount(), 4, "component count after remove")) return;

if (!expect(go.nativeHandle.isPersistent(), "native handle is persistent")) return;
if (!expect(go.nativeHandle.isPayloadAlive(), "native handle payload alive before destroy")) return;

if (!expect(world.destroyGameObject(0), "destroyGameObject succeeds")) return;
if (!expectEq(world.objectCount(), 0, "world empty after destroy")) return;
if (!expectEq(_gcProbePersistentManualPayloadCount(), 1, "manual payload destroy count after object destroy")) return;
if (!expectEq(_gcProbePersistentAutoPayloadCount(), 0, "no auto payload destroy before shutdown")) return;

world = nil;
go = nil;
_gc();
_gc();

if (!expectEq(_gcProbePersistentAutoPayloadCount(), 0, "gc still does not destroy persistent payload")) return;

print("FAKE_ENGINE_GENERIC_PASS");
