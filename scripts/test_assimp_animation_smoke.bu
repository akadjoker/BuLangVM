require "Assimp";
import Assimp;
using Assimp;

def fail(msg)
{
    print("ASSIMP_ANIMATION_SMOKE_FAIL", msg);
}

def expect(cond, msg)
{
    if (!cond)
    {
        fail(msg);
        return false;
    }
    return true;
}

var scene = AssimpScene();
var importFlags = Triangulate | GenSmoothNormals | JoinIdenticalVertices | FlipUVs | LimitBoneWeights;

var candidatePaths = [
    "vendor/assimp/test/models-nonbsd/B3D/dwarf2.b3d",
    "../vendor/assimp/test/models-nonbsd/B3D/dwarf2.b3d",
    "vendor/assimp/test/models-nonbsd/B3D/turtle1.b3d",
    "../vendor/assimp/test/models-nonbsd/B3D/turtle1.b3d",
    "vendor/assimp/test/models-nonbsd/FBX/2013_BINARY/multiple_animations_test.fbx",
    "../vendor/assimp/test/models-nonbsd/FBX/2013_BINARY/multiple_animations_test.fbx"
];

var loaded = false;
var loadedPath = "";
for (var i = 0; i < candidatePaths.length(); i = i + 1)
{
    loaded = scene.load(candidatePaths[i], importFlags);
    if (loaded)
    {
        loadedPath = candidatePaths[i];
        break;
    }
}

if (!expect(loaded, "scene load failed: " + scene.getError())) return;

if (!expect(scene.isValid(), "scene not valid")) return;
if (!expect(scene.getMeshCount() > 0, "scene has no meshes")) return;
if (!expect(scene.getAnimationCount() > 0, "scene has no animations")) return;

var root = scene.getRootNode();
if (!expect(root != nil, "scene missing root node")) return;
if (!expect(root.getChildCount() > 0, "root has no children")) return;
if (!expect(root.getTransform() != nil, "root transform missing")) return;

var meshWithBones = nil;
for (var i = 0; i < scene.getMeshCount(); i = i + 1)
{
    var mesh = scene.getMesh(i);
    if (mesh != nil && mesh.getBoneCount() > 0)
    {
        meshWithBones = mesh;
        break;
    }
}

if (meshWithBones != nil)
{
    if (!expect(meshWithBones.getBoneWeightCount(0) > 0, "first bone has no weights")) return;

    var boneName = meshWithBones.getBoneName(0);
    if (!expect(boneName != "", "empty bone name")) return;
    if (!expect(scene.findNodeByName(boneName) != nil, "bone node not found in scene")) return;

    var (vertexId, weight) = meshWithBones.getBoneWeight(0, 0);
    if (!expect(vertexId >= 0, "invalid bone vertex id")) return;
    if (!expect(weight > 0.0, "invalid bone weight")) return;
}

var anim = scene.getAnimation(0);
if (!expect(anim != nil, "missing first animation")) return;
if (!expect(anim.getChannelCount() > 0, "animation has no channels")) return;

var channel = anim.getChannel(0);
if (!expect(channel != nil, "missing first channel")) return;
var nodeName = channel.getNodeName();
if (!expect(nodeName != "", "channel node name empty")) return;
if (!expect(anim.findChannel(nodeName) != nil, "findChannel failed")) return;

if (!expect(channel.getPositionKeyCount() > 0, "channel missing position keys")) return;
if (!expect(channel.getRotationKeyCount() > 0, "channel missing rotation keys")) return;

var sampledA = anim.sampleNodeTransform(nodeName, 0.0, true);
var sampledB = channel.sampleTransform(0.12, true);
if (!expect(sampledA != nil, "animation sample returned nil")) return;
if (!expect(sampledB != nil, "channel sample returned nil")) return;

scene.free();
print("ASSIMP_ANIMATION_SMOKE_PATH", loadedPath);
print("ASSIMP_ANIMATION_SMOKE_PASS");
