// Gameplay state
var PI = 3.141592653589793;
var fixedStep = 1.0 / 60.0;
var accumulator = 0.0;
var reportedStepError = false;

var world = nil;
var chassis = nil;
var tank = nil;

var wheelRadius = 0.30;
var wheelHalfWidth = 0.05;
var chassisHalfWidth = 1.7;
var chassisHalfHeight = 0.5;
var chassisHalfLength = 3.2;

var previousForward = 1.0;
var turretYaw = 0.0;
var barrelPitch = -0.03;
var fireCooldown = 0.0;

var sceneBodies = [];
var dynamicBodies = [];
var shells = [];
var explosions = [];
var sparks = [];

var camX = 0.0;
var camY = 0.0;
var camZ = 0.0;
var camReady = false;
var lightAngle = 0.0;

var split0 = 24.0;
var split1 = 68.0;

var sparkBatch = Batch(1, 32768);
var uiBatch = Batch(1, 4096);
var uiFont = SpriteFont();
