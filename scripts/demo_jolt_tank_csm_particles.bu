}


def buildMeshFromShape(shapeId)
{
    if (shapeId == 0) return nil;

    var pbuf = ShapeGetPositions(shapeId);
    var nbuf = ShapeGetNormals(shapeId);
    var ibuf = ShapeGetIndices(shapeId);
    if (pbuf == nil || nbuf == nil || ibuf == nil) return nil;

    var pos = Float32Array(pbuf);
    var nrm = Float32Array(nbuf);
    var idx = Uint16Array(ibuf);

    var vcount = int(pos.length() / 3);
    if (vcount <= 0) return nil;

    var tbuf = ShapeGetTexCoords(shapeId);
    var uv = nil;
    if (tbuf != nil)
    {
        uv = Float32Array(tbuf);
        if (uv.length() < vcount * 2) uv = nil;
    }

    if (uv == nil)
    {
        uv = Float32Array(vcount * 2);
        for (var i = 0; i < vcount; i++)
        {
            var b = i * 3;
            uv.add(pos.get(b) * 0.15 + 0.5, pos.get(b + 2) * 0.15 + 0.5);
        }
    }

    var tang = Float32Array(vcount * 3);
    for (var i = 0; i < vcount; i++) tang.add(0.0, 0.0, 0.0);

    var ic = idx.length();
    for (var i = 0; i < ic; i = i + 3)
    {
        var i0 = int(idx.get(i + 0));
        var i1 = int(idx.get(i + 1));
        var i2 = int(idx.get(i + 2));

        var p0 = i0 * 3; var p1 = i1 * 3; var p2 = i2 * 3;
        var u0 = i0 * 2; var u1 = i1 * 2; var u2 = i2 * 2;

        var x1 = pos.get(p1 + 0) - pos.get(p0 + 0);
        var y1 = pos.get(p1 + 1) - pos.get(p0 + 1);
        var z1 = pos.get(p1 + 2) - pos.get(p0 + 2);

        var x2 = pos.get(p2 + 0) - pos.get(p0 + 0);
        var y2 = pos.get(p2 + 1) - pos.get(p0 + 1);
        var z2 = pos.get(p2 + 2) - pos.get(p0 + 2);

        var s1 = uv.get(u1 + 0) - uv.get(u0 + 0);
        var t1 = uv.get(u1 + 1) - uv.get(u0 + 1);
        var s2 = uv.get(u2 + 0) - uv.get(u0 + 0);
        var t2 = uv.get(u2 + 1) - uv.get(u0 + 1);

        var den = s1 * t2 - s2 * t1;
        var aden = den;
        if (aden < 0.0) aden = -aden;
        if (aden < 0.000001) continue;

        var r = 1.0 / den;
        var tx = (x1 * t2 - x2 * t1) * r;
        var ty = (y1 * t2 - y2 * t1) * r;
        var tz = (z1 * t2 - z2 * t1) * r;

        var t0 = i0 * 3; var tA = i1 * 3; var tB = i2 * 3;
        tang.set(t0 + 0, tang.get(t0 + 0) + tx);
        tang.set(t0 + 1, tang.get(t0 + 1) + ty);
        tang.set(t0 + 2, tang.get(t0 + 2) + tz);

        tang.set(tA + 0, tang.get(tA + 0) + tx);
        tang.set(tA + 1, tang.get(tA + 1) + ty);
        tang.set(tA + 2, tang.get(tA + 2) + tz);

        tang.set(tB + 0, tang.get(tB + 0) + tx);
        tang.set(tB + 1, tang.get(tB + 1) + ty);
        tang.set(tB + 2, tang.get(tB + 2) + tz);
    }

    for (var i = 0; i < vcount; i++)
    {
        var b = i * 3;
        var nx = nrm.get(b + 0);
        var ny = nrm.get(b + 1);
        var nz = nrm.get(b + 2);

        var tx = tang.get(b + 0);
        var ty = tang.get(b + 1);
        var tz = tang.get(b + 2);

        var dt = nx * tx + ny * ty + nz * tz;
        tx = tx - nx * dt;
        ty = ty - ny * dt;
        tz = tz - nz * dt;

        var tlen = sqrt(tx * tx + ty * ty + tz * tz);
        if (tlen < 0.00001)
        {
            var anx = nx;
            if (anx < 0.0) anx = -anx;
            if (anx < 0.9)
            {
                tx = 0.0;
                ty = nz;
                tz = -ny;
            }
            else
            {
                tx = ny;
                ty = -nx;
                tz = 0.0;
            }
            tlen = sqrt(tx * tx + ty * ty + tz * tz);
        }

        if (tlen < 0.00001) tlen = 1.0;
        tang.set(b + 0, tx / tlen);
        tang.set(b + 1, ty / tlen);
        tang.set(b + 2, tz / tlen);
    }

    var verts = Float32Array(vcount * 11);
    for (var i = 0; i < vcount; i++)
    {
        var p = i * 3;
        var u = i * 2;
        verts.add(
            pos.get(p + 0), pos.get(p + 1), pos.get(p + 2),
            nrm.get(p + 0), nrm.get(p + 1), nrm.get(p + 2),
            uv.get(u + 0), uv.get(u + 1),
            tang.get(p + 0), tang.get(p + 1), tang.get(p + 2)
        );
    }

    var vao = glGenVertexArrays();
    var vbo = glGenBuffers();
    var ebo = glGenBuffers();

    glBindVertexArray(vao);
    glBindBuffer(GL_ARRAY_BUFFER, vbo);
    glBufferData(GL_ARRAY_BUFFER, verts.byteLength(), verts, GL_STATIC_DRAW);
    glBindBuffer(GL_ELEMENT_ARRAY_BUFFER, ebo);
    glBufferData(GL_ELEMENT_ARRAY_BUFFER, idx.byteLength(), idx, GL_STATIC_DRAW);

    var stride = 11 * 4;
    glEnableVertexAttribArray(0);
    glVertexAttribPointer(0, 3, GL_FLOAT, false, stride, 0);
    glEnableVertexAttribArray(1);
    glVertexAttribPointer(1, 3, GL_FLOAT, false, stride, 3 * 4);
    glEnableVertexAttribArray(2);
    glVertexAttribPointer(2, 2, GL_FLOAT, false, stride, 6 * 4);
    glEnableVertexAttribArray(3);
    glVertexAttribPointer(3, 3, GL_FLOAT, false, stride, 8 * 4);
    glBindVertexArray(0);

    return MeshGL(vao, vbo, ebo, idx.length());
}

def drawMesh(mesh)
{
    if (mesh == nil) return;
    glBindVertexArray(mesh.vao);
    glDrawElements(GL_TRIANGLES, mesh.count, GL_UNSIGNED_SHORT, 0);
    glBindVertexArray(0);
}

def freeMesh(mesh)
{
    if (mesh == nil) return;
    glDeleteBuffers(mesh.vbo);
    glDeleteBuffers(mesh.ebo);
    glDeleteVertexArrays(mesh.vao);
}

def createNormalMapTexture(size)
{
    var pixels = Uint8Array(size * size * 3);

    for (var y = 0; y < size; y++)
    {
        for (var x = 0; x < size; x++)
        {
            var fx = x / size;
            var fy = y / size;

            var nx = sin(fx * 52.0) * cos(fy * 41.0) * 0.75;
            var ny = cos(fx * 37.0 + fy * 29.0) * 0.75;
            var nz = 1.0;

            var nlen = sqrt(nx * nx + ny * ny + nz * nz);
            nx = nx / nlen;
            ny = ny / nlen;
            nz = nz / nlen;

            pixels.add(
                int((nx * 0.5 + 0.5) * 255.0),
                int((ny * 0.5 + 0.5) * 255.0),
                int((nz * 0.5 + 0.5) * 255.0)
            );
        }
    }

    var tex = glGenTextures();
    glBindTexture(GL_TEXTURE_2D, tex);
    glTexImage2D(GL_TEXTURE_2D, 0, GL_RGB, size, size, 0, GL_RGB, GL_UNSIGNED_BYTE, pixels);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_LINEAR_MIPMAP_LINEAR);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_LINEAR);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_REPEAT);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_REPEAT);
    glGenerateMipmap(GL_TEXTURE_2D);
    return tex;
}

def makeShadowTarget(size)
{
    var fbo = glGenFramebuffers();
    var texDepth = glGenTextures();
    var texColor = glGenTextures();

    glBindTexture(GL_TEXTURE_2D, texDepth);
    glTexImage2D(GL_TEXTURE_2D, 0, GL_DEPTH_COMPONENT24, size, size, 0, GL_DEPTH_COMPONENT, GL_FLOAT, nil);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_NEAREST);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_NEAREST);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_CLAMP_TO_EDGE);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_CLAMP_TO_EDGE);

    glBindTexture(GL_TEXTURE_2D, texColor);
    glTexImage2D(GL_TEXTURE_2D, 0, GL_RGBA8, size, size, 0, GL_RGBA, GL_UNSIGNED_BYTE, nil);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_NEAREST);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_NEAREST);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_CLAMP_TO_EDGE);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_CLAMP_TO_EDGE);

    glBindFramebuffer(GL_FRAMEBUFFER, fbo);
    glFramebufferTexture2D(GL_FRAMEBUFFER, GL_DEPTH_ATTACHMENT, GL_TEXTURE_2D, texDepth, 0);
    glFramebufferTexture2D(GL_FRAMEBUFFER, GL_COLOR_ATTACHMENT0, GL_TEXTURE_2D, texColor, 0);
    glDrawBuffers(1, [GL_COLOR_ATTACHMENT0]);
    var status = glCheckFramebufferStatus(GL_FRAMEBUFFER);
    glBindFramebuffer(GL_FRAMEBUFFER, 0);

    if (status != GL_FRAMEBUFFER_COMPLETE)
    {
        print("CSM target incomplete status=" + status);
        return nil;
    }

    return ShadowTarget(fbo, texDepth, texColor, size);
}

def freeShadowTarget(st)
{
    if (st == nil) return;
    glDeleteTextures(st.depth);
    glDeleteTextures(st.color);
    glDeleteFramebuffers(st.fbo);
}


