SetGLVersion(3, 3, SDL_GL_CONTEXT_PROFILE_COMPATIBILITY);
SetGLAttribute(SDL_GL_DOUBLEBUFFER, 1);
SetGLAttribute(SDL_GL_DEPTH_SIZE, 24);
if (!Init("BuGL Jolt Tank CSM + Sparks", 1280, 720, SDL_WINDOW_OPENGL | SDL_WINDOW_RESIZABLE)) return;

glEnable(GL_DEPTH_TEST);
glEnable(GL_CULL_FACE);
glCullFace(GL_BACK);
glEnable(GL_BLEND);
glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
glClearColor(0.06, 0.08, 0.11, 1.0);

def getWindowSizeSafe()
{
    var w = GetWidth();
    var h = GetHeight();
    if (w <= 0) w = 1;
    if (h <= 0) h = 1;
    return (w, h);
}

var (bootW, bootH) = getWindowSizeSafe();
glViewport(0, 0, bootW, bootH);

def loadShaderProgramAuto(vertexName, fragmentName)
{
    var rootBase = "assets/shaders/";
    var scriptBase = "../assets/shaders/";
    var rootV = rootBase + vertexName;
    var rootF = rootBase + fragmentName;
    var scriptV = scriptBase + vertexName;
    var scriptF = scriptBase + fragmentName;

    var prog = 0;
    if (path.exists(rootV) && path.exists(rootF))
        prog = LoadShaderProgram(rootV, rootF);
    else if (path.exists(scriptV) && path.exists(scriptF))
        prog = LoadShaderProgram(scriptV, scriptF);
    else
        print("Shader source not found: " + vertexName + " / " + fragmentName);

    if (prog == nil) prog = 0;
    return prog;
}

var progDepth = loadShaderProgramAuto("depth.vert", "depth.frag");
var progScene = loadShaderProgramAuto("csm_scene_v3.vert", "csm_scene_v3.frag");
var progSky = loadShaderProgramAuto("sky_proc.vert", "sky_proc.frag");
if (progDepth <= 0 || progScene <= 0)
{
    print("Failed to load CSM shaders.");
    Quit();
}
if (progSky <= 0) print("Warning: procedural sky shader disabled.");

